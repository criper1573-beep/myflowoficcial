# ============================================
# ОБЩИЕ НАСТРОЙКИ (один завод — много проектов)
# API ИИ общий для всех проектов
# ============================================
GRS_AI_API_KEY=your_grs_ai_api_key_here
GRS_AI_API_URL=https://grsaiapi.com

# Проект по умолчанию (если не передан в командной строке)
PROJECT_ID=flowcabinet

# ============================================
# Telegram (опционально в .env)
# If using projects — set in blocks/projects/data/<id>.yaml
# Иначе — здесь. Создать бота: https://t.me/BotFather
# ============================================
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHANNEL_ID=@your_channel
# TELEGRAM_ALLOW_NO_COVER=false   # true — при отсутствии обложки отправлять пост в канал только текстом (оркестратор/lifehacks)

# ============================================
# Post FLOW (блок blocks/post_flow)
# Посты из Google Таблицы в канал FLOW
# ============================================
# GOOGLE_SHEET_ID=1gxYpX1FGm5VwtyUoZNKdd8EVYduvkmULpXL5TuOv5z4
# GOOGLE_CREDENTIALS_PATH=credentials.json
# TOPICS_SHEET_NAME=Лист1
# TELEGRAM_CHANNEL=@myflowofficial
# MODEL_GENERATION=gemini-3-pro
# MODEL_FALLBACK=gpt-4o-mini
# IMAGE_MODEL=nano-banana

# ============================================
# OpenAI (опционально)
# Получить: https://platform.openai.com/api-keys
# ============================================
# OPENAI_API_KEY=sk-...
# OPENAI_ORG_ID=org-...

# ============================================
# Yandex GPT (опционально)
# Получить: https://cloud.yandex.ru/
# ============================================
# YANDEX_API_KEY=your_yandex_api_key
# YANDEX_FOLDER_ID=your_folder_id

# ============================================
# VK API (опционально)
# Получить: https://vk.com/apps?act=manage
# ============================================
# VK_ACCESS_TOKEN=your_vk_access_token
# VK_GROUP_ID=123456789
# VK_API_VERSION=5.131

# ============================================
# Яндекс.Дзен (опционально)
# Получить: https://zen.yandex.ru/
# ============================================
# YANDEX_ZEN_TOKEN=your_zen_token
# YANDEX_ZEN_CHANNEL_ID=your_channel_id

# Дзен автопостинг (Playwright) — blocks/autopost_zen/
# Cookies: python docs/scripts/scripts/capture_cookies.py --url https://dzen.ru
# ZEN_EMAIL=...
# ZEN_PASSWORD=...
# ZEN_STORAGE_STATE=zen_storage_state.json
# ZEN_EDITOR_URL=https://dzen.ru/profile/editor/flowcabinet
# ZEN_HEADLESS=false
# ZEN_BROWSER_TIMEOUT=60000   # мс; при таймаутах загрузки страницы Дзен можно увеличить (например 90000)
# ZEN_KEEP_OPEN=false
# GRS_IMAGE_TIMEOUT=120       # сек; таймаут запроса к GRS Draw API (обложка/картинки); при «google gemini timeout» можно 180

# ============================================
# Дзен автопостинг — автогенерация статей (--auto)
# Тема берётся из Лист2 Google Sheets (отдельно от Лист1 для Telegram)
# ============================================
# ZEN_TOPICS_SHEET_NAME=Лист2
# ZEN_ARTICLE_MODEL=gemini-2.5-pro
# ZEN_HEADLINE_MODEL=gpt-4o-mini
# ZEN_IMAGE_MODEL=nano-banana-pro
# ZEN_COVER_REF_FACE=https://i.postimg.cc/jdwFhwpV/photo_2026_02_05_10_46_02.jpg

# ============================================
# Яндекс Вордстат API (сбор ключевых слов и частотности)
# Документация: https://yandex.ru/support2/wordstat/ru/content/api-wordstat
# Получить: https://oauth.yandex.ru/ → создать приложение → подать заявку на доступ к API
# ============================================
# YANDEX_WORDSTAT_TOKEN=y0__your_oauth_token_here

# ============================================
# Аналитика пайплайна + Telegram Mini App (blocks/analytics)
# Дашборд: python -m blocks.analytics. Бот для /stats и кнопки «Дашборд»: python -m blocks.analytics.telegram_bot
# ============================================
# DASHBOARD_PUBLIC_URL=https://your-dashboard.example.com
# Для Mini App в Telegram обязателен HTTPS (деплой или туннель ngrok/cloudflared).

# Локальный дашборд: откуда подтягивать статус сервисов (только не-Linux).
# Укажи URL сервера с дашбордом — блок «Сервисы на сервере» будет показывать данные с него.
# ANALYTICS_SERVER_SERVICES_URL=http://85.198.66.62

# Quickpack: если сайт без systemd-юнита — на сервере задай URL для проверки (дашборд и watchdog проверяют по HTTP 200).
# QUICKPACK_URL=https://твой-сайт-quickpack.ru

# Generation (картинки/ссылки с flowimage.ru): если на дашборде пустой раздел — задай путь к блоку grs_image_web на сервере.
# GRS_IMAGE_WEB_DIR=/root/contentzavod/blocks/grs_image_web
# Либо по отдельности: GRS_IMAGE_WEB_GENERATED_DIR=...  GRS_IMAGE_WEB_UPLOADED_DIR=...

# Watchdog: уведомления в Telegram при падении сервисов (дашборд, бот, спамбот).
# TELEGRAM_ALERT_CHAT_ID=123456789   # id чата: написать @userinfobot или отправить боту /start и посмотреть getUpdates
# WATCHDOG_INTERVAL=90               # интервал проверки в секундах (по умолчанию 90)

# ============================================
# Генерация изображений — веб-страница (blocks/grs_image_web)
# Запуск: python -m blocks.grs_image_web
# Авторизация через Telegram Login Widget; история генераций по аккаунту.
# ============================================
# TELEGRAM_BOT_TOKEN=...   # тот же бот или отдельный: для верификации данных виджета «Войти через Telegram»
# GRS_IMAGE_WEB_BOT_USERNAME=YourImageBot   # имя бота без @ — для отображения кнопки «Войти через Telegram» (в BotFather: /setdomain для домена сайта)
# GRS_IMAGE_WEB_REQUIRE_AUTH=true   # включить авторизацию через Telegram (по умолчанию false — локальный режим без входа)
# GRS_IMAGE_WEB_SESSION_SECRET=...  # опционально: секрет для подписи сессии (по умолчанию используется TELEGRAM_BOT_TOKEN)
# GRS_IMAGE_WEB_HOST=127.0.0.1      # хост (для сервера: 0.0.0.0)
# GRS_IMAGE_WEB_PORT=8765           # порт

# ============================================
# Визуализатор кабинетов FlowCabinet (blocks/flowcabinet_visualizer)
# Запуск: python -m blocks.flowcabinet_visualizer
# Для генерации 3 вариантов используется GRS AI (GRS_AI_API_KEY, GRS_AI_API_URL выше).
# Админ-панель: /admin — референсы и промпты; защита паролем.
# ============================================
# FLOWCABINET_VIZ_HOST=127.0.0.1   # хост (для сервера: 0.0.0.0)
# FLOWCABINET_VIZ_PORT=8777        # порт
# FLOWCABINET_VIZ_ADMIN_PASSWORD=  # пароль для доступа к /admin (если не задан — админка недоступна)

# ============================================
# Доска скриптов диалогов (blocks/script_board)
# Запуск: python -m blocks.script_board. Генерация ответов через GRS AI (GRS_AI_API_KEY выше).
# Деплой на script.flowcabinet.ru: docs/guides/DEPLOY_SCRIPT_BOARD.md, docs/scripts/deploy_beget/deploy_script_board.ps1
# ============================================
# SCRIPT_BOARD_HOST=127.0.0.1   # хост (для сервера: 0.0.0.0)
# SCRIPT_BOARD_PORT=8780        # порт

# ============================================
# SSH-доступ к серверу (VPS)
# Для деплоя, перезапуска сервисов, мониторинга.
# SERVER_HOST и DEPLOY_SSH_PASSWORD — активный сервер для скриптов.
# Чтобы переключиться — подставь значения из секции РФ или Латвии.
# ============================================
# SERVER_HOST=85.198.66.62
# SERVER_USER=root
# DEPLOY_SSH_PASSWORD=your_ssh_password_here

# --- Сервер РФ ---
# SERVER_RF_HOST=85.198.66.62
# SERVER_RF_SSH_PASSWORD=your_rf_server_password

# --- Сервер Латвии ---
# SERVER_LV_HOST=your_latvia_server_ip
# SERVER_LV_SSH_PASSWORD=your_latvia_server_password

# ============================================
# Amnezia VPN (опционально)
# Проверка VPS перед настройкой: python docs/scripts/check_amnezia_server.py
# ============================================
# AMNEZIA_VPS_IP=1.2.3.4
# AMNEZIA_SSH_USER=root

# ============================================
# Zakazy Forwarder (blocks/zakazy_forwarder)
# Чтение чата t.me/zakazyff и пересылка сообщений «Новый Заказ на упаковку и отгрузку»
# Запуск: python -m blocks.zakazy_forwarder
# ============================================
# TELEGRAM_API_ID=12345678
# TELEGRAM_API_HASH=your_api_hash_from_my_telegram_org
# ZAKAZY_SOURCE=zakazyff
# ZAKAZY_DESTINATION=@channel_or_chat   # или числовой chat_id, например -1001234567890
# ZAKAZY_TRIGGER=Новый Заказ на упаковку и отгрузку
# ZAKAZY_BOT_TOKEN=123456:ABC...   # токен бота для отправки (например @exsamplepless_bot)

# ============================================
# Pinterest (опционально)
# Получить: https://developers.pinterest.com/
# ============================================
# PINTEREST_ACCESS_TOKEN=your_pinterest_token
# PINTEREST_BOARD_ID=your_board_id

# ============================================
# vc.ru (опционально)
# Получить: https://vc.ru/api
# ============================================
# VCRU_TOKEN=your_vcru_token
# VCRU_SUBSECTION_ID=123456

# ============================================
# База данных (опционально)
# ============================================
# DATABASE_URL=sqlite:///storage/content.db
# DATABASE_URL=postgresql://user:password@localhost/dbname

# ============================================
# Логирование
# ============================================
LOG_LEVEL=INFO
LOG_FILE=storage/logs/app.log

# ============================================
# Другие настройки
# ============================================
# ENVIRONMENT=development
# DEBUG=False
